o\",{\"d\":\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"}],[\"$\",\"path\",\"19qd67\",{\"d\":\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"}]],\"$undefined\"]}]]}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Dasharr is a modern dashboard framework that allows developers to build beautiful, responsive dashboards with minimal effort.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"The goal of Dasharr is to be simple and developer-friendly. There are other dashboard solutions like Grafana or Metabase, but they often require complex setups and configurations for custom use cases.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Additionally, what makes Dasharr special is that it focuses on real-time data visualization with a component-first approach, which means you can build custom widgets and layouts easily. Some developers might prefer traditional BI tools at first, but we believe component-based dashboards are the future, and once you try building with Dasharr, you'll appreciate the flexibility and control it provides. For example, you can now create custom visualizations that perfectly match your brand and data requirements.\"}],\"\\n\",[\"$\",\"h2\",null,{\"className\":\"flex scroll-m-28 flex-row items-center gap-2\",\"id\":\"key-features\",\"children\":[[\"$\",\"a\",null,{\"data-card\":\"\",\"href\":\"#key-features\",\"className\":\"peer\",\"children\":\"Key Features\"}],[\"$\",\"svg\",null,{\"ref\":\"$undefined\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"width\":24,\"height\":24,\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"strokeWidth\":2,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"lucide size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\",\"aria-label\":\"Link to section\",\"children\":[[[\"$\",\"path\",\"1cjeqo\",{\"d\":\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"}],[\"$\",\"path\",\"19qd67\",{\"d\":\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"}]],\"$undefined\"]}]]}],\"\\n\",[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Component-Based Architecture\"}],\": Build dashboards using reusable components\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Real-Time Updates\"}],\": Live data streaming and automatic refresh\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Responsive Design\"}],\": Works perfectly on desktop, tablet, and mobile\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Easy Integration\"}],\": Connect to any data source with our flexible API\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Customizable Themes\"}],\": Match your brand with custom styling\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"h2\",null,{\"className\":\"flex scroll-m-28 flex-row items-center gap-2\",\"id\":\"getting-started\",\"children\":[[\"$\",\"a\",null,{\"data-card\":\"\",\"href\":\"#getting-started\",\"className\":\"peer\",\"children\":\"Getting Started\"}],[\"$\",\"svg\",null,{\"ref\":\"$undefined\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"width\":24,\"height\":24,\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"strokeWidth\":2,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"lucide size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\",\"aria-label\":\"Link to section\",\"children\":[[[\"$\",\"path\",\"1cjeqo\",{\"d\":\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"}],[\"$\",\"path\",\"19qd67\",{\"d\":\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"}]],\"$undefined\"]}]]}],\"\\n\",[\"$\",\"p\",null,{\"children\":[\"To get started with Dasharr, check out our \",\"$L2b\",\" or explore our \",\"$L2c\",\" to see what's possible.\"]}]],\"classN