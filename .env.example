# Dasharr Runtime Configuration
# This file contains runtime configuration for the Dasharr container
# Copy this file to .env and configure with your values
# DO NOT commit the .env file to version control
# https://dasharr.io for documentation

# ========================================
# Application Settings
# ========================================
# All of these have hardcoded defaults if not set

# Port the application will run on (default: 3000)
# PORT=3000

# Host binding (default: 0.0.0.0 for all interfaces)
# HOST=0.0.0.0

# Timezone for the application (default: America/New_York)
# Find your timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/New_York

# Full URL where the application is accessible (default: http://localhost:3000)
# Used for generating absolute URLs
# APP_URL=http://localhost:3000

# Enable if running behind a reverse proxy (default: false)
# Set to true if using nginx, Caddy, Cloudflare, etc.
# TRUST_PROXY=false

# User and group IDs for file permissions in Docker (default: 1000)
# PUID=1000
# PGID=1000

# ========================================
# Service API Keys and URLs
# ========================================
# Configure these through the web interface at /admin
# or set them here directly
# NOTE: Environment variables take precedence over web configuration

# Plex Configuration
# Find your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
# PLEX_URL=http://your-plex-server:32400
# PLEX_TOKEN=your-plex-token

# Jellyfin Configuration
# API key created in Dashboard > API Keys
# JELLYFIN_URL=http://your-jellyfin:8096
# JELLYFIN_API_KEY=your-jellyfin-api-key

# Jellyseerr Configuration
# API key found in Settings > General > API Key
# JELLYSEERR_URL=http://your-jellyseerr:5055
# JELLYSEERR_API_KEY=your-jellyseerr-api-key

# Radarr Configuration
# API key found in Settings > General > Security
# RADARR_URL=http://your-radarr:7878
# RADARR_API_KEY=your-radarr-api-key

# Sonarr Configuration
# API key found in Settings > General > Security
# SONARR_URL=http://your-sonarr:8989
# SONARR_API_KEY=your-sonarr-api-key

# Tautulli Configuration
# API key found in Settings > Web Interface > API
# TAUTULLI_URL=http://your-tautulli:8181
# TAUTULLI_API_KEY=your-tautulli-api-key

# SABnzbd Configuration
# API key found in Config > General > Security
# Use the FULL API key, not the NZB key
# SABNZBD_URL=http://your-sabnzbd:8080
# SABNZBD_API_KEY=your-sabnzbd-api-key

# Prowlarr Configuration
# API key found in Settings > General > Security
# PROWLARR_URL=http://your-prowlarr:9696
# PROWLARR_API_KEY=your-prowlarr-api-key

# qBittorrent Configuration
# Enable Web UI in Options > Web UI
# QBITTORRENT_URL=http://your-qbittorrent:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=your-password

# Overseerr Configuration
# API key found in Settings > General > API Key
# OVERSEERR_URL=http://your-overseerr:5055
# OVERSEERR_API_KEY=your-overseerr-api-key

# UniFi Configuration
# Number of UniFi sites to configure (default: 1)
# UNIFI_SITES=1
# 
# For each site, configure the URL, API key, and display name
# Replace N with the site number (1, 2, 3, etc.)
# UNIFI_URL_SITE_1=https://your-unifi-controller:8443
# UNIFI_API_KEY_1=your-unifi-api-key-1
# UNIFI_SITE_NAME_1=Home Network
# 
# UniFi Site Manager configuration (optional)
# Only enable if you have a UniFi Cloud account with Site Manager
# UNIFI_SITE_MANAGER=false
# UNIFI_SITE_MANAGER_API_KEY=your-site-manager-api-key

# ========================================
# WebSocket Configuration
# ========================================
# WebSocket URL for Cloudflare Worker integration
# CLOUDFLARE_WORKER_WS_URL=wss://your-worker.your-subdomain.workers.dev/ws

# Container identifier for WebSocket client (default: dasharr-default)
# CONTAINER_ID=dasharr-default

# Enable WebSocket functionality (default: true)
# ENABLE_WEBSOCKET=true

# Metrics collection interval in seconds (default: 30)
# REFRESH_INTERVAL=30

# ========================================
# Logging
# ========================================
# Log level: error, warn, info, debug (default: info)
# LOG_LEVEL=info
